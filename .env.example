# ============================================
# TREVA Concreto — Configuración de entorno
# ============================================
# Copia este archivo como .env.local y completa los valores

# Google Analytics 4
# Ve a https://analytics.google.com → Administrar → Crear stream → Web
# El ID tiene formato G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console
# Ve a https://search.google.com/search-console → Añadir propiedad → Tag HTML
# Copia solo el contenido del content, ej: "1234567890abcdef"
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=1234567890abcdef
